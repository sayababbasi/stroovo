generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  password        String
  role            Role      @default(TEAM_MEMBER)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        String?
  comments        Comment[]
  goals           Goal[]    @relation("GoalOwner")
  managedProjects Project[] @relation("ProjectManager")
  tasks           Task[]    @relation("TaskAssignee")
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cycles    Cycle[]
  goals     Goal[]
  users     User[]
}

model Cycle {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("ACTIVE")
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  goals     Goal[]
}

model Goal {
  id          String      @id @default(cuid())
  title       String
  description String?
  status      String      @default("ON_TRACK")
  progress    Int         @default(0)
  targetDate  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  ownerId     String
  cycleId     String?
  parentId    String?
  tenantId    String?
  type        String      @default("COMPANY")
  cycle       Cycle?      @relation(fields: [cycleId], references: [id])
  owner       User        @relation("GoalOwner", fields: [ownerId], references: [id])
  parent      Goal?       @relation("GoalHierarchy", fields: [parentId], references: [id])
  subGoals    Goal[]      @relation("GoalHierarchy")
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  keyResults  KeyResult[]
  projects    Project[]
}

model KeyResult {
  id           String   @id @default(cuid())
  title        String
  initialValue Float    @default(0)
  currentValue Float    @default(0)
  targetValue  Float
  unit         String   @default("NUMBER")
  weight       Float    @default(1.0)
  goalId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  managerId   String
  goalId      String?
  isStarred   Boolean   @default(false)
  goal        Goal?     @relation(fields: [goalId], references: [id])
  manager     User      @relation("ProjectManager", fields: [managerId], references: [id])
  tasks       Task[]
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  projectId   String
  assigneeId  String?
  parentId    String?
  progress    Int          @default(0)
  type        String       @default("TASK")
  comments    Comment[]
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  parent      Task?        @relation("SubTasks", fields: [parentId], references: [id])
  subTasks    Task[]       @relation("SubTasks")
  project     Project      @relation(fields: [projectId], references: [id])
  files       TaskFile[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model TaskFile {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER
  GUEST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BACKLOG
  REVIEW
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
